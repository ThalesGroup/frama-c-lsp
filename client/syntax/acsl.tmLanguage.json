{
    "name": "ACSL language support for Visual Studio Code",
    "scopeName": "source.c.acsl",
    "injectionSelector": "L:source.c -comment -string",
    "patterns": [
        { "include": "#annotation" },
        { "include": "#inline-annotation" }
    ],
    "repository": {
        "annotation" : {
            			"begin": "\\s*+(\\/\\*\\@)",
						"end": "\\*\\/",
            "beginCaptures": {
				"0": { "name": "entity.section.acsl" }
            },
            "endCaptures": {
				"0": { "name": "entity.section.acsl" }
            },
            "patterns": [
                { "include": "#comment" },
                { "include": "#label" },
                { "include": "#keyword" },
                { "include": "#supported-function" },
                { "include": "#operators" },
                { "include": "#numbers" },
                { "include": "#function"}
            ]
        },
        "inline-annotation": {
			"begin": "\\s*(\\/\\/@)\\s",
    		"end": ";",
            "beginCaptures": {
				"0": { "name": "entity.section.acsl" }
            },
            "endCaptures": {
				"0": { "name": "entity.section.acsl" }
			},
            "patterns": [
                { "include": "#keyword" },
                { "include": "#label" },
                { "include": "#supported-function" },
                { "include": "#operators" },
                { "include": "#numbers" },
                { "include": "#function" }
            ]
        },
        "comment": {
            "patterns": [
                {
                    "name": "comment.line.double-slash.acsl",
                    "begin": "//",
                    "end": "\\n"
                }
            ]
        },
        "keyword": {
            "patterns": [
                  {
                "name": "variable.language.acsl",
				"match": "\\b(admits|assert|assigns|assumes|allocates|axiom|axiomatic|ghost|behavior|behaviors|breaks|case|char|checks|complete|continues|decreases|disjoint|double|else|ensures|enum|exits|float|for|frees|if|inductive|int|integer|invariant|global|label|lemma|logic|long|loop|pragma|predicate|reads|real|requires|returns|short|signed|sizeof|slice|impact|struct|terminates|type|union|unsigned|variant|void)\\b"
			}]
        },
        "supported-function": {
            "patterns": [{
				"name": "keyword.control.acsl",
				"match": "\\\\\\b([a-zA-Z0-9\\_]*)\\b"
			}]
		},
       "operators": {
			"patterns": [
				{ "include": "#binary-operator" },
				{ "include": "#unary-operator" }
			]
		},
        "binary-operator": {
			"patterns": [
				{
					"name": "keyword.operator.acsl",
					"match": "(\\+|-|\\*|/|%|<<|>>|==|!=|<=|>=|>|<|&&|\\|\\||&|-->|<-->|\\^|\\^\\^|\\.\\.)"
				}
			]
		},
		"unary-operator": {
			"patterns": [
				{
					"name": "keyword.operator.acsl",
					"match": "(\\+|-|\\*|/|%|<<|>>|==|!=|<=|>=|>|<|&&|\\|\\||&|-->|<-->|\\^|\\^\\^|\\.\\.)"
				}
			]
		},
        "numbers": {
            "patterns": [
                {
                    "name": "constant.numeric.acsl",
                    "match": "\\b((0(x|X)[0-9a-fA-F]([0-9a-fA-F']*[0-9a-fA-F])?)|(0(b|B)[01]([01']*[01])?)|(([0-9]([0-9']*[0-9])?\\.?[0-9]*([0-9']*[0-9])?)|(\\.[0-9]([0-9']*[0-9])?))((e|E)(\\+|-)?[0-9]([0-9']*[0-9])?)?)(L|l|UL|ul|u|U|F|f|ll|LL|ull|ULL)?\\b"
                }
            ]
        },
        "label": {
            "patterns": [
                { "include": "#keyword" },
                {
                    "name": "entity.name.label.acsl",
                    "match": "\\s*([a-zA-Z0-9\\_]*)\\s*:\\s*"
                }
            ]
        },
        "function": {
			"patterns": [
				{ "include": "#supported-function" },
				{
					"match": "\\b\\w+(?=\\((\\\\?\\w+\\s*,?\\s*)*\\))",
					"name": "entity.name.function.acsl"
				 },
				 {
					"match": "\\b\\w+(?=\\{(\\w+\\s*,?\\s*)*\\}(\\((\\w+\\s*,?\\s*)*\\))?)",
					"name": "entity.name.function.acsl"
				}
			]
		}
    }
}